# syntax=docker/dockerfile:1
# web(Next.js) 런타임 이미지. 멀티스테이지: deps → builder → runner.
# 최종 이미지는 .next/standalone(최소 산출물)만 담아 작고, 비루트 유저로 실행한다.

# --- deps: 의존성 설치(빌드에 dev 의존성 필요) ---
FROM node:26-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

# --- builder: Next standalone 빌드 ---
FROM node:26-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# NEXT_PUBLIC_* 는 빌드 시 클라이언트 번들에 인라인된다(공개 값: URL·anon 키).
# compose/CLI에서 --build-arg 로 주입한다. 시크릿(service_role)은 여기 절대 넣지 않는다.
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_TELEMETRY_DISABLED=1
# 컨테이너 런타임은 .next/standalone(server.js)으로 기동하므로 이 빌드에서만 standalone을 켠다.
ENV BUILD_STANDALONE=1
RUN npm run build

# --- runner: standalone 산출물만 ---
FROM node:26-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
RUN addgroup -g 1001 -S nodejs && adduser -u 1001 -S nextjs -G nodejs
# standalone 서버(server.js)와 정적 자산을 복사. public/ 은 현재 없어 생략.
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
USER nextjs
EXPOSE 3000
# 컨테이너 헬스체크(docker/compose용 — k8s에선 liveness/readiness probe가 담당). /health/live 확인.
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD wget -qO- http://127.0.0.1:3000/health/live >/dev/null 2>&1 || exit 1
CMD ["node", "server.js"]
