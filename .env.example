# 앱과 워커가 같은 .env.local 을 쓴다 (git 미추적, 시크릿 안전).

# 앱(Next) — 클라이언트 노출
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# 워커(worker/worker.mjs) — 서버 전용. NEXT_PUBLIC_ 접두사가 없어 브라우저에 노출되지 않는다.
# URL은 위 NEXT_PUBLIC_SUPABASE_URL 을 재사용하므로 이 한 줄만 추가하면 된다.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY   # Supabase 대시보드 Settings > API. 절대 커밋 금지!

# 선택(공통)
APP_ENV=dev                  # 로그 env 라벨 (dev/staging/prod)
LOG_LEVEL=info               # debug|info|warn|error

# OpenTelemetry 트레이싱 — span을 OTLP/HTTP로 export. 미설정 시 http://localhost:4318(로컬 Jaeger) 기본.
# (docker compose로 띄울 땐 compose가 http://jaeger:4318 로 덮어쓴다 — 컨테이너 네트워크는 서비스명으로 닿음.)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # 호스트에서 직접 실행 시 로컬 Jaeger 포트
OTEL_SERVICE_NAME=dailyproof-web                   # web 서비스 이름(worker는 코드에서 dailyproof-worker 고정)
WORKER_POLL_IDLE_MS=2000     # 빈 큐일 때 폴링 간격(ms)
WORKER_RETRY_BASE_MS=5000    # 처리 실패 시 지수 백오프 기준(ms). 테스트 땐 1000 등으로 낮춰도 됨
WORKER_CALL_TIMEOUT_MS=10000 # 외부 호출(claim/download) 시간 제한(ms)
